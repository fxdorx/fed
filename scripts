RightGroupBoxPlayers:AddToggle('LoopFlingPlayerMain', {
    Text = 'Loop Fling Player',
    Default = false,
    Tooltip = 'Flings the player fast, snaps you back clean, repeats when they land',
    Callback = function(Value)
        LoopFlingPlayerEnabled = Value
        if LoopFlingPlayerEnabled then
            if not SelectedPlayerForFling or SelectedPlayerForFling == "" then
                Options.LoopFlingPlayerMain:SetValue(false)
                return
            end
            spawn(function()
                while LoopFlingPlayerEnabled do
                    local targetPlayer = Players:FindFirstChild(SelectedPlayerForFling)
                    if not targetPlayer or not targetPlayer.Character then
                        task.wait(1)
                        continue
                    end

                    local _Humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
                    local _Root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")

                    if not _Humanoid or not _Root then
                        task.wait(1)
                        continue
                    end

                    -- Only fling when target is on the ground
                    if _Root.Velocity.Magnitude > 50 then
                        task.wait(0.3)
                        continue
                    end

                    -- Save our position before starting
                    local OldPosition = HumanoidRootPart.CFrame
                    local Flinging = true

                    -- The velocity pump that makes the fling actually work
                    spawn(function()
                        local Movel = 0.1
                        repeat
                            task.wait()
                            local Velocity = HumanoidRootPart.Velocity
                            HumanoidRootPart.Velocity = Velocity * 10000 + Vector3.new(0, 10000, 0)
                            RunService.RenderStepped:Wait()
                            HumanoidRootPart.Velocity = Velocity
                            RunService.Stepped:Wait()
                            HumanoidRootPart.Velocity = Velocity + Vector3.new(0, Movel, 0)
                            Movel = Movel * -1
                        until not Flinging
                    end)

                    -- Prediction-based positioning loop (2 second window or until flung)
                    local Start = tick()
                    camera.CameraSubject = _Humanoid
                    Humanoid.Sit = false

                    repeat
                        task.wait()
                        local Magnitude = _Root.Velocity.Magnitude
                        local Direction = _Humanoid.MoveDirection or Vector3.zero
                        local PredictionOffset

                        if Magnitude < 5 then
                            PredictionOffset = Vector3.new(0, math.random(-10, 4) / 10, 0)
                        else
                            local rng = 0.7 + math.random() * 7.3
                            PredictionOffset = Direction * (Magnitude / rng) - Vector3.new(0, math.random(-10, 10) / 10, 0)
                        end

                        local PredictedCFrame = CFrame.new(_Root.Position + PredictionOffset)
                        Humanoid.Sit = false
                        HumanoidRootPart.CFrame = PredictedCFrame * CFrame.Angles(math.random(0, 360), 0, 0)

                    until (tick() - Start >= 2)
                        or (_Root.Velocity.Magnitude > 200)
                        or not _Root
                        or not _Root.Parent
                        or not LoopFlingPlayerEnabled

                    -- Stop the velocity pump
                    Flinging = false

                    -- Snap us back to original position cleanly
                    HumanoidRootPart.CFrame = OldPosition
                    for _, part in ipairs(Character:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.Velocity = Vector3.new(0, 0, 0)
                            part.RotVelocity = Vector3.new(0, 0, 0)
                        end
                    end
                    camera.CameraSubject = Humanoid

                    -- Wait for target to land before going again
                    if LoopFlingPlayerEnabled then
                        local landWait = tick()
                        repeat
                            task.wait(0.2)
                            local tp = Players:FindFirstChild(SelectedPlayerForFling)
                            if not tp or not tp.Character then break end
                            local hrp = tp.Character:FindFirstChild("HumanoidRootPart")
                            if not hrp then break end
                            if tick() - landWait > 10 then break end
                        until not LoopFlingPlayerEnabled
                            or not Players:FindFirstChild(SelectedPlayerForFling)
                            or (Players:FindFirstChild(SelectedPlayerForFling)
                                and Players:FindFirstChild(SelectedPlayerForFling).Character
                                and Players:FindFirstChild(SelectedPlayerForFling).Character:FindFirstChild("HumanoidRootPart")
                                and Players:FindFirstChild(SelectedPlayerForFling).Character.HumanoidRootPart.Velocity.Magnitude < 25)
                    end
                end
            end)
        else
            LoopFlingPlayerEnabled = false
        end
    end
})

