-- Walk Speed (multi-method loop to bypass anti-cheat)
LeftGroupBoxLocal:AddToggle('WalkSpeed', {
    Text = 'Walk Speed',
    Default = false,
    Tooltip = 'Loop-sets walk speed every step, works against most anti-cheat',
    Callback = function(Value)
        WalkSpeedEnabled = Value
        if WalkSpeedEnabled then
            if walkSpeedConnection then walkSpeedConnection:Disconnect() end

            walkSpeedConnection = RunService.Heartbeat:Connect(function()
                if not WalkSpeedEnabled then return end

                -- Re-grab humanoid every tick in case of respawn
                local char = LocalPlayer.Character
                if not char then return end
                local hum = char:FindFirstChildOfClass("Humanoid")
                if not hum then return end

                -- Method 1: direct property
                hum.WalkSpeed = WalkSpeed

                -- Method 2: fire via ChangeProperty if method 1 gets reverted
                if hum.WalkSpeed ~= WalkSpeed then
                    hum.WalkSpeed = WalkSpeed
                end

                -- Method 3: if the game uses a BodyVelocity to cap speed, destroy it
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, v in ipairs(hrp:GetChildren()) do
                        if v:IsA("BodyVelocity") or v:IsA("BodyForce") then
                            v:Destroy()
                        end
                    end
                end

                -- Method 4: re-apply via RootPart velocity nudge to prevent dampening
                if hrp and hum.MoveDirection.Magnitude > 0 then
                    local currentSpeed = Vector3.new(
                        hrp.AssemblyLinearVelocity.X,
                        0,
                        hrp.AssemblyLinearVelocity.Z
                    ).Magnitude

                    if currentSpeed > 0 and currentSpeed < WalkSpeed * 0.85 then
                        local dir = hrp.AssemblyLinearVelocity * Vector3.new(1, 0, 1)
                        if dir.Magnitude > 0 then
                            hrp.AssemblyLinearVelocity = Vector3.new(
                                dir.Unit.X * WalkSpeed,
                                hrp.AssemblyLinearVelocity.Y,
                                dir.Unit.Z * WalkSpeed
                            )
                        end
                    end
                end
            end)

        else
            if walkSpeedConnection then
                walkSpeedConnection:Disconnect()
                walkSpeedConnection = nil
            end
            local char = LocalPlayer.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then hum.WalkSpeed = defaultWalkspeed end
            end
        end
    end
})

