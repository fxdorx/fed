do
    local antiFlingActive = false
    local lockedCFrame = nil
    local heartbeatConn = nil
    local charConn = nil

    local function getHRP()
        local char = LocalPlayer.Character
        return char and char:FindFirstChild("HumanoidRootPart")
    end

    local function getHumanoid()
        local char = LocalPlayer.Character
        return char and char:FindFirstChildOfClass("Humanoid")
    end

    local function freezeAll(hrp)
        local char = hrp.Parent
        if not char then return end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.AssemblyLinearVelocity = Vector3.zero
                part.AssemblyAngularVelocity = Vector3.zero
            end
        end
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end

    local function isOnGround(hrp)
        -- Raycast straight down from HRP, if it hits within ~3.5 studs we are grounded
        local rayOrigin = hrp.Position
        local rayDirection = Vector3.new(0, -3.5, 0)
        local raycastParams = RaycastParams.new()
        raycastParams.FilterDescendantsInstances = {hrp.Parent}
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        local result = workspace:Raycast(rayOrigin, rayDirection, raycastParams)
        return result ~= nil
    end

    local function startLoop()
        if heartbeatConn then heartbeatConn:Disconnect() end

        local hrp = getHRP()
        if not hrp then return end

        lockedCFrame = hrp.CFrame
        local settleTime = tick() + 1.5
        local stillTimer = 0

        heartbeatConn = RunService.Heartbeat:Connect(function(dt)
            if not antiFlingActive then return end

            local h = getHRP()
            if not h then return end

            local vel = h.AssemblyLinearVelocity
            local hSpeed = Vector3.new(vel.X, 0, vel.Z).Magnitude
            local vSpeed = vel.Y

            local isFling = (hSpeed > 40) or (vSpeed < -45) or (vSpeed > 75)

            if isFling then
                h.Anchored = true
                freezeAll(h)
                h.CFrame = lockedCFrame
                freezeAll(h)

                local hum = getHumanoid()
                if hum then hum.PlatformStand = true end

                task.defer(function()
                    if not antiFlingActive then return end
                    local h2 = getHRP()
                    if h2 then
                        h2.Anchored = false
                        h2.AssemblyLinearVelocity = Vector3.zero
                        h2.AssemblyAngularVelocity = Vector3.zero
                        h2.CFrame = lockedCFrame
                    end
                    local hum2 = getHumanoid()
                    if hum2 then hum2.PlatformStand = false end
                end)

            else
                local hum = getHumanoid()
                local grounded = isOnGround(h)
                -- FloorMaterial being Air means they are airborne
                local onFloor = hum and hum.FloorMaterial ~= Enum.Material.Air

                -- Must be: past settle time, on the ground (both raycast AND FloorMaterial agree),
                -- completely still horizontally, and not bouncing vertically
                if tick() > settleTime
                    and grounded
                    and onFloor
                    and hSpeed < 2
                    and math.abs(vSpeed) < 1
                then
                    stillTimer = stillTimer + dt
                    if stillTimer >= 0.3 then
                        lockedCFrame = h.CFrame
                    end
                else
                    stillTimer = 0
                end
            end
        end)
    end

    local function stopLoop()
        if heartbeatConn then
            heartbeatConn:Disconnect()
            heartbeatConn = nil
        end
        local hrp = getHRP()
        if hrp then hrp.Anchored = false end
        local hum = getHumanoid()
        if hum then hum.PlatformStand = false end
        lockedCFrame = nil
    end

    local function onCharacterAdded(char)
        lockedCFrame = nil
        if antiFlingActive then
            char:WaitForChild("HumanoidRootPart")
            startLoop()
        end
    end

    if charConn then charConn:Disconnect() end
    charConn = LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

    LeftGroupBoxLocal:AddToggle('AntiFling', {
        Text = 'Anti Fling',
        Default = false,
        Tooltip = 'Snaps you back to your last grounded still position the moment a fling is detected',
        Callback = function(Value)
            antiFlingActive = Value
            if Value then
                startLoop()
            else
                stopLoop()
            end
        end
    })
end


-- Walk Fling
LeftGroupBoxLocal:AddToggle('WalkFling', {
    Text = 'Walk Fling',
    Default = false,
    Tooltip = 'Flings players you walk into',
    Callback = function(Value)
        WalkFlingEnabled = Value
        if Value then
            Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
            Humanoid.BreakJointsOnDeath = false
            HumanoidRootPart.CanCollide = false
            Humanoid:ChangeState(11)
            spawn(function()
                while WalkFlingEnabled and HumanoidRootPart and HumanoidRootPart.Parent do
                    RunService.Heartbeat:Wait()
                    local vel = HumanoidRootPart.Velocity
                    HumanoidRootPart.Velocity = vel * 99999999 + Vector3.new(0, 99999999, 0)
                    RunService.RenderStepped:Wait()
                    HumanoidRootPart.Velocity = vel
                    RunService.Stepped:Wait()
                    HumanoidRootPart.Velocity = vel + Vector3.new(0, 0.1, 0)
                end
            end)
        else
            if Character and Humanoid then
                Humanoid:ChangeState(Enum.HumanoidStateType.Landed)
            end
        end
    end
})

