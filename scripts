LeftGroupBoxLocal:AddLabel('Free Cam'):AddKeyPicker('FreeCam', {
    Default = 'C',
    SyncToggleState = true,
    Mode = 'Toggle',
    Text = 'Free Cam',
    NoUI = false,
    Callback = function(Value)
        FreeCamEnabled = Value
        if Value then
            if Options.FirstPerson then Options.FirstPerson:SetValue(false) end
            if Options.ThirdPerson then Options.ThirdPerson:SetValue(false) end
            camera.CameraType = Enum.CameraType.Scriptable
            UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
            local camCFrame = camera.CFrame
            local pitch = 0
            local yaw = 0
            local mouseConn = UserInputService.InputChanged:Connect(function(input)
                if not FreeCamEnabled then return end
                if input.UserInputType == Enum.UserInputType.MouseMovement then
                    yaw = yaw - input.Delta.X * 0.004
                    pitch = math.clamp(pitch - input.Delta.Y * 0.004, -math.pi/2 + 0.1, math.pi/2 - 0.1)
                end
            end)
            freeCamConnection = RunService.RenderStepped:Connect(function(dt)
                if not FreeCamEnabled then
                    if mouseConn then mouseConn:Disconnect() end
                    return
                end
                local speed = 50 * dt
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then speed = speed * 3 end
                local rotation = CFrame.Angles(0, yaw, 0) * CFrame.Angles(pitch, 0, 0)
                local move = Vector3.new(0, 0, 0)
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + rotation.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - rotation.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - rotation.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + rotation.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.E) then move = move + Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.Q) then move = move - Vector3.new(0, 1, 0) end
                camCFrame = camCFrame + (move * speed)
                camera.CFrame = CFrame.new(camCFrame.Position) * rotation
            end)
        else
            if freeCamConnection then freeCamConnection:Disconnect() freeCamConnection = nil end
            UserInputService.MouseBehavior = Enum.MouseBehavior.Default
            camera.CameraType = Enum.CameraType.Custom
            camera.CameraSubject = Humanoid
        end
    end
})


