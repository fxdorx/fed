do
    local droneCamActive = false
    local droneConn = nil
    local charConn2 = nil
    local dronePart = nil
    local droneSpeed = 60
    local droneFastSpeed = 180
    local droneSensitivity = 0.25

    local Camera = workspace.CurrentCamera
    local UIS = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    local Mouse = LocalPlayer:GetMouse()

    local yaw = 0
    local pitch = 0
    local lastMousePos = nil

    local function getHRP()
        local char = LocalPlayer.Character
        return char and char:FindFirstChild("HumanoidRootPart")
    end

    local function getHumanoid()
        local char = LocalPlayer.Character
        return char and char:FindFirstChildOfClass("Humanoid")
    end

    local function lockCharacter(locked)
        local hrp = getHRP()
        local hum = getHumanoid()
        if hrp then
            hrp.Anchored = locked
            if locked then
                hrp.AssemblyLinearVelocity = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
            end
        end
        if hum then
            hum.WalkSpeed = locked and 0 or 16
            hum.JumpPower = locked and 0 or 50
            hum.PlatformStand = locked
        end
    end

    local function createDronePart()
        local hrp = getHRP()
        if not hrp then return nil end
        local part = Instance.new("Part")
        part.Name = "DroneCamPart"
        part.Size = Vector3.new(0.1, 0.1, 0.1)
        part.Transparency = 1
        part.CanCollide = false
        part.CanQuery = false
        part.CanTouch = false
        part.Anchored = true
        part.CFrame = hrp.CFrame * CFrame.new(0, 3, 0)
        part.Parent = workspace
        return part
    end

    local function startDrone()
        if droneConn then
            droneConn:Disconnect()
            droneConn = nil
        end

        local hrp = getHRP()
        if not hrp then return end

        lockCharacter(true)

        dronePart = createDronePart()
        if not dronePart then return end

        local lv = hrp.CFrame.LookVector
        yaw = math.atan2(-lv.X, -lv.Z)
        pitch = 0
        lastMousePos = nil

        Camera.CameraType = Enum.CameraType.Scriptable
        Camera.CFrame = dronePart.CFrame
        UIS.MouseIconEnabled = false

        droneConn = RunService.RenderStepped:Connect(function(dt)
            if not droneCamActive then return end

            -- Force camera type back EVERY frame so clicks cant steal it
            if Camera.CameraType ~= Enum.CameraType.Scriptable then
                Camera.CameraType = Enum.CameraType.Scriptable
            end

            -- Force camera subject to nil so Roblox default controller has nothing to attach to
            if Camera.CameraSubject ~= nil then
                Camera.CameraSubject = nil
            end

            local mx = Mouse.X
            local my = Mouse.Y

            if lastMousePos then
                local dx = mx - lastMousePos.X
                local dy = my - lastMousePos.Y

                if math.abs(dx) < 100 and math.abs(dy) < 100 then
                    yaw   = yaw - dx * droneSensitivity * dt
                    pitch = math.clamp(
                        pitch - dy * droneSensitivity * dt,
                        math.rad(-89),
                        math.rad(89)
                    )
                end
            end

            lastMousePos = Vector2.new(mx, my)

            local camCF   = CFrame.Angles(0, yaw, 0) * CFrame.Angles(pitch, 0, 0)
            local forward = camCF.LookVector
            local right   = camCF.RightVector
            local worldUp = Vector3.new(0, 1, 0)

            local moveDir = Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W)     then moveDir += forward end
            if UIS:IsKeyDown(Enum.KeyCode.S)     then moveDir -= forward end
            if UIS:IsKeyDown(Enum.KeyCode.A)     then moveDir -= right   end
            if UIS:IsKeyDown(Enum.KeyCode.D)     then moveDir += right   end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then moveDir += worldUp end
            if UIS:IsKeyDown(Enum.KeyCode.Q)     then moveDir -= worldUp end

            local speed = UIS:IsKeyDown(Enum.KeyCode.LeftShift)
                and droneFastSpeed
                or droneSpeed

            if moveDir.Magnitude > 0 then
                moveDir = moveDir.Unit
            end

            local newPos = dronePart.CFrame.Position + moveDir * speed * dt
            dronePart.CFrame = CFrame.new(newPos)
                * CFrame.Angles(0, yaw, 0)
                * CFrame.Angles(pitch, 0, 0)

            -- Force camera onto drone part every single frame no matter what
            Camera.CFrame = dronePart.CFrame

            local h = getHRP()
            if h then
                h.AssemblyLinearVelocity  = Vector3.zero
                h.AssemblyAngularVelocity = Vector3.zero
            end
        end)
    end

    local function stopDrone()
        if droneConn then
            droneConn:Disconnect()
            droneConn = nil
        end

        if dronePart then
            dronePart:Destroy()
            dronePart = nil
        end

        UIS.MouseIconEnabled = true
        UIS.MouseBehavior    = Enum.MouseBehavior.Default

        Camera.CameraType    = Enum.CameraType.Custom
        local char = LocalPlayer.Character
        Camera.CameraSubject = char
            and char:FindFirstChildOfClass("Humanoid")
            or nil

        lockCharacter(false)
        lastMousePos = nil
    end

    local function onCharacterAdded2(char)
        if droneCamActive then
            char:WaitForChild("HumanoidRootPart")
            stopDrone()
            startDrone()
        end
