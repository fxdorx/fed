local function UpdateMainStatus()
    if not StatusLabelMain then return end
    local nearbyLines = {}
    local friendLines = {}
    local featureLines = {}

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local hasChar = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hasChar then
                local dist = math.floor((HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude)
                if dist <= 60 then
                    table.insert(nearbyLines, player.Name .. "  (" .. dist .. " studs)")
                end
            end
            pcall(function()
                if LocalPlayer:IsFriendsWith(player.UserId) then
                    table.insert(friendLines, player.Name)
                end
            end)
        end
    end

    local function featureStatus(label, state)
        table.insert(featureLines, label .. ": " .. (state and "On" or "Off"))
    end

    featureStatus("Infinite Jump", InfJumpEnabled)
    featureStatus("Walk Speed", WalkSpeedEnabled)
    featureStatus("Fly", FlyEnabled)
    featureStatus("Anti-Fling", AntiFlingEnabled)
    featureStatus("Walk Fling", WalkFlingEnabled)
    featureStatus("Aimbot", AimbotEnabled)
    featureStatus("Loop TP", LoopTeleportPlayerEnabled)
    featureStatus("Loop Fling", LoopFlingPlayerEnabled)
    featureStatus("Fling All", Loopvoid)
    featureStatus("Stay Grounded", StayGroundedEnabled)
    featureStatus("Loop Reset", LoopResetEnabled)
    featureStatus("View Player", ViewPlayerEnabled)

    local nearbyText = #nearbyLines > 0 and table.concat(nearbyLines, "\n") or "None"
    local friendText = #friendLines > 0 and table.concat(friendLines, ", ") or "None"
    local featText = table.concat(featureLines, "\n")
    local targetText = SelectedPlayerForTP or "None"

    StatusLabelMain:SetText(
        "Target: " .. targetText ..
        "\nServer: " .. #Players:GetPlayers() .. " players" ..
        "\n\nFriends In Game:\n" .. friendText ..
        "\n\nNearby (60 studs):\n" .. nearbyText ..
        "\n\nFeatures:\n" .. featText
    )
end

RunService.Heartbeat:Connect(function()
    pcall(UpdateMainStatus)
end)

