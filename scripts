-- Server status label
StatusLabelServer = LeftGroupBoxServer:AddLabel('Loading...', true)

local function UpdateServerStatus()
    if not StatusLabelServer then return end
    local totalPlayers = #Players:GetPlayers()
    local nearbyCount = 0
    local inViewCount = 0
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if dist <= 50 then nearbyCount = nearbyCount + 1 end
            local _, onScreen = camera:WorldToScreenPoint(player.Character.HumanoidRootPart.Position)
            if onScreen then inViewCount = inViewCount + 1 end
        end
    end
    StatusLabelServer:SetText(
        "Server Players: " .. totalPlayers ..
        "\nNearby (50s): " .. nearbyCount ..
        "\nIn View: " .. inViewCount ..
        "\n\nPlayer Check: " .. (PlayerCheckEnabled and "On" or "Off") ..
        "\nCheck Delay: " .. PlayerCheckDelay .. "s" ..
        "\n\nMessage Spam: " .. (SpamMessageEnabled and "On" or "Off") ..
        "\nSpam Delay: " .. SpamMessageDelay .. "s" ..
        "\nMessage: " .. (MessageText ~= "" and MessageText or "(empty)")
    )
end

RunService.Heartbeat:Connect(function()
    pcall(UpdateServerStatus)
end)

