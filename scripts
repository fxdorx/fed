-- Stay Grounded
LeftGroupBoxLocal:AddToggle('StayGrounded', {
    Text = 'Stay Grounded',
    Default = false,
    Tooltip = 'Pins you to the ground every frame - no escape no matter how high you go',
    Callback = function(Value)
        StayGroundedEnabled = Value
        if StayGroundedEnabled then
            stayGroundedConnection = RunService.Heartbeat:Connect(function()
                if not StayGroundedEnabled then return end
                local raycastParams = RaycastParams.new()
                raycastParams.FilterDescendantsInstances = {Character}
                raycastParams.FilterType = Enum.RaycastFilterType.Exclude
                -- Cast from way above current position so we find ground even if we're at 10000 studs
                local castOrigin = Vector3.new(HumanoidRootPart.Position.X, HumanoidRootPart.Position.Y + 50, HumanoidRootPart.Position.Z)
                local result = Workspace:Raycast(castOrigin, Vector3.new(0, -100000, 0), raycastParams)
                if result then
                    local groundY = result.Position.Y + 3
                    if HumanoidRootPart.Position.Y > groundY + 0.1 then
                        -- Stay anchored this frame, slam to ground, kill all velocity
                        -- Keep anchored so physics absolutely cannot push us back up
                        HumanoidRootPart.Anchored = true
                        HumanoidRootPart.CFrame = CFrame.new(
                            HumanoidRootPart.Position.X,
                            groundY,
                            HumanoidRootPart.Position.Z
                        ) * CFrame.Angles(0, HumanoidRootPart.CFrame:ToEulerAnglesYXZ(), 0)
                        HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
                        HumanoidRootPart.RotVelocity = Vector3.new(0, 0, 0)
                    else
                        -- We are at ground level - unanchor so we can walk normally
                        HumanoidRootPart.Anchored = false
                    end
                end
            end)
        else
            if stayGroundedConnection then
                stayGroundedConnection:Disconnect()
                stayGroundedConnection = nil
            end
            if HumanoidRootPart then HumanoidRootPart.Anchored = false end
        end
    end
})

